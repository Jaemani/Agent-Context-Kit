{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Jaemani/Agent-Context-Kit/main/schemas/config-v1.schema.json",
  "title": "Agent Context Kit configuration v1",
  "description": "Public structural contract for .agent-context/config.yaml. Runtime validation applies additional filesystem portability and collision checks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "documents", "adapters", "policies"],
  "properties": {
    "version": { "const": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^(?!\\s)(?!.*\\s$)(?!.*agent-context-kit:managed:)[^\\u0000-\\u001f\\u007f-\\u009f\\ud800-\\udfff\\u2028\\u2029]+$"
        }
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "contains": {
        "type": "object",
        "required": ["load"],
        "properties": { "load": { "const": "always" } }
      },
      "items": { "$ref": "#/$defs/document" }
    },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/adapter" }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAlwaysCharacters", "maxAdapterCharacters"],
      "properties": {
        "maxAlwaysCharacters": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 100000
        },
        "maxAdapterCharacters": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 100000
        }
      }
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!\\s)(?!.*\\s$)(?!/)(?![A-Za-z]:/)(?!.*\\\\)(?!.*//)(?!.*agent-context-kit:managed:)(?!.*(?:^|/)\\.\\.?/)[^\\u0000-\\u001f\\u007f-\\u009f\\ud800-\\udfff\\u2028\\u2029]+$"
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "load", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": { "$ref": "#/$defs/portablePath" },
        "load": { "enum": ["always", "on-demand"] },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240,
          "pattern": "^(?!\\s)(?!.*\\s$)(?!.*agent-context-kit:managed:)[^\\u0000-\\u001f\\u007f-\\u009f\\ud800-\\udfff\\u2028\\u2029]+$"
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "pattern": "^(?!\\s)(?!.*\\s$)(?!.*agent-context-kit:managed:)[^\\u0000-\\u001f\\u007f-\\u009f\\ud800-\\udfff\\u2028\\u2029]+$"
          }
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "output"],
      "properties": {
        "type": { "enum": ["codex", "claude"] },
        "output": { "$ref": "#/$defs/portablePath" }
      }
    }
  }
}
